# Configuration Template
# Copy this file to .env and fill in your values

# Security: Your unique API Key for device authentication
# You can generate a secure key using the internal CLI (feature coming soon)
# or by running: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here

# Network Settings
BASE_URL=http://127.0.0.1
HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Rate Limiting (e.g., '35/minute', '100/hour')
DEFAULT_RATE_LIMIT=35/minute

# Frontend Access
# The password required to access the Streamlit dashboard
FRONTEND_PASSWORD=your_password_here